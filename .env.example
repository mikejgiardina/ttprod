# Trauma Tracker — server-side secrets (Netlify Functions only; NEVER exposed to the browser).
# Copy to `.env` and fill in. `.env` is gitignored.

# --- Anthropic (Extractor / Scribe + Nurse's Note + Debrief agents) ---
# Verify the exact model ids against the current Claude API reference before wiring the whitelist.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL_EXTRACTOR=claude-sonnet-5
ANTHROPIC_MODEL_NOTE=claude-sonnet-5

# --- Speech-to-text (ADR-0013 pending sign-off; default target is Deepgram Nova-3 Medical) ---
# STT_VENDOR is the single swap point for the adapter (deepgram | webspeech | mock).
STT_VENDOR=mock
DEEPGRAM_API_KEY=

# --- demo flags ---
# When VITE_DEMO_MODE=canned, the app runs the deterministic engine off the bundled
# canned transcript with no mic / STT / model calls (fallback floor).
VITE_DEMO_MODE=canned
